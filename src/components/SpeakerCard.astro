---
import { Image } from 'astro:assets';
import type { Speaker } from '../data/site';

interface Props {
  speaker: Speaker;
}

const { speaker } = Astro.props;

const englishName = speaker.name.split('·')[0].trim();
const initials = englishName
  .split(/\s+/)
  .map((word) => word[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();
const linkLabel = speaker.link?.includes('linkedin') ? 'LinkedIn' : 'Homepage';
---

<article class:list={['speaker-card', { 'is-tba': speaker.tba }]}>
  <div class="speaker-avatar">
    {speaker.image ? (
      <Image
        class="speaker-photo"
        src={speaker.image}
        alt={`Portrait of ${englishName}`}
        width={96}
        densities={[1, 2]}
        format="webp"
      />
    ) : speaker.tba ? (
      <span class="avatar-mark tba" aria-hidden="true">?</span>
    ) : (
      <span class="avatar-mark monogram" aria-hidden="true">{initials}</span>
    )}
  </div>

  <p class="tag">{speaker.topic}</p>
  <h3>
    {speaker.link ? (
      <a href={speaker.link} target="_blank" rel="noopener noreferrer">{speaker.name}</a>
    ) : (
      speaker.name
    )}
  </h3>
  <p class="role">{speaker.affiliation}</p>
  <p>{speaker.body}</p>

  {speaker.link && (
    <a class="speaker-link" href={speaker.link} target="_blank" rel="noopener noreferrer">
      {linkLabel} <span aria-hidden="true">↗</span>
    </a>
  )}
  {speaker.tba && <p class="speaker-tba-note">Speaker to be announced</p>}
</article>
