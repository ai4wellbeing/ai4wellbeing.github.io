---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import SpeakerCard from '../components/SpeakerCard.astro';
import { sponsors, workshop } from '../data/site';
---

<Layout
  title="Events · Cambridge AI for Wellbeing Society"
  description={`${workshop.title} on ${workshop.date} — five speakers from AI-driven drug discovery to machine learning for materials, plus one open speaking slot.`}
>
  <PageHeader eyebrow="Events · First Workshop" title={workshop.title} lede={workshop.summary}>
    <p class="workshop-meta">
      {workshop.date} · {workshop.location} · <span>{workshop.note}</span>
    </p>
  </PageHeader>

  <section class="section tight-top" aria-labelledby="speakers-title">
    <div class="section-heading">
      <p class="eyebrow">Speakers</p>
      <h2 id="speakers-title">Five frontiers of AI for human health.</h2>
    </div>
    <div class="speaker-grid">
      {workshop.speakers.map((speaker) => <SpeakerCard speaker={speaker} />)}
    </div>
    <div class="section-cta">
      <a class="button primary" href="/contact/">Register interest</a>
      <a class="text-link" href="/contact/">Propose a talk</a>
    </div>
  </section>

  <section class="section accent tight-top" aria-labelledby="sponsors-title">
    <div class="section-heading">
      <p class="eyebrow">Sponsors &amp; Supporters</p>
      <h2 id="sponsors-title">Made possible with their support.</h2>
    </div>
    <ul class="sponsor-strip">
      {sponsors.map((sponsor) => (
        <li class="sponsor">
          <a href={sponsor.url} target="_blank" rel="noopener noreferrer" aria-label={sponsor.name}>
            <img
              class="sponsor-logo"
              src={sponsor.logo}
              alt={`${sponsor.name} logo`}
              style={`height: ${sponsor.height}px`}
              loading="lazy"
            />
          </a>
          <span class="sponsor-tier">{sponsor.tier}</span>
        </li>
      ))}
    </ul>
  </section>
</Layout>
