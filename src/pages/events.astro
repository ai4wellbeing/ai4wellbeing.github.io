---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { workshop } from '../data/site';
---

<Layout
  title="Events · Cambridge AI for Wellbeing Society"
  description={`${workshop.title} on ${workshop.date}: AI for drug discovery, robotics and embodied intelligence, and biotech.`}
>
  <PageHeader eyebrow="Events · First Workshop" title={workshop.title} lede={workshop.summary}>
    <p class="workshop-meta">
      {workshop.date} · {workshop.location} · <span>{workshop.note}</span>
    </p>
  </PageHeader>

  <section class="section tight-top" aria-labelledby="speakers-title">
    <div class="section-heading">
      <p class="eyebrow">Speakers</p>
      <h2 id="speakers-title">Three frontiers of AI for human health.</h2>
    </div>
    <div class="three-grid">
      {workshop.speakers.map((speaker) => (
        <article class="panel">
          <p class="tag">{speaker.topic}</p>
          <h3>{speaker.name}</h3>
          <p class="role">{speaker.affiliation}</p>
          <p>{speaker.body}</p>
        </article>
      ))}
    </div>
    <div class="section-cta">
      <a class="button primary" href="/contact/">Register interest</a>
      <a class="text-link" href="/contact/">Propose a talk</a>
    </div>
  </section>
</Layout>
