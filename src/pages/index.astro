---
import { Image, Picture, getImage } from 'astro:assets';
import '../styles/global.css';
import { events, focusAreas, mission, navItems, people, projects } from '../data/site';
import logo from '../assets/ai4w-logo.png';
import brandBanner from '../assets/ai4w-logo-big.png';
import heroImage from '../assets/hero.png';

const contactFormEndpoint = import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT?.trim() ?? '';
const isContactFormConfigured = contactFormEndpoint.length > 0;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

const ogWidth = 1200;
const ogHeight = Math.round((heroImage.height / heroImage.width) * ogWidth);
const ogImage = await getImage({ src: heroImage, width: ogWidth, format: 'jpeg' });
const ogImageUrl = new URL(ogImage.src, Astro.site).href;

const organizationSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Cambridge AI for Wellbeing Society',
  url: Astro.site,
  logo: new URL('/apple-touch-icon.png', Astro.site).href,
  sameAs: ['https://github.com/ai4wellbeing']
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Cambridge AI for Wellbeing Society is an interdisciplinary community for responsible AI research, education, and human wellbeing."
    />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content="Cambridge AI for Wellbeing Society" />
    <meta
      property="og:description"
      content="Responsible AI research, education, and community for human wellbeing."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(ogWidth)} />
    <meta property="og:image:height" content={String(ogHeight)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#133844" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>Cambridge AI for Wellbeing Society</title>
    <script type="application/ld+json" set:html={organizationSchema} />
  </head>
  <body>
    <a class="skip-link" href="#top">Skip to content</a>
    <header class="site-header">
      <a class="brand" href="#top" aria-label="Cambridge AI for Wellbeing Society home">
        <Image class="brand-logo" src={logo} alt="" width={46} densities={[1, 2]} format="webp" />
        <span>
          <strong>Cambridge AI for Wellbeing Society</strong>
          <small>Responsible AI for human wellbeing</small>
        </span>
      </a>
      <nav aria-label="Primary navigation">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <Picture
          class="hero-image"
          src={heroImage}
          formats={['avif', 'webp']}
          fallbackFormat="jpg"
          widths={[640, 1024, 1440, heroImage.width]}
          sizes="100vw"
          alt="Cambridge-inspired academic courtyard with subtle AI network light patterns"
          loading="eager"
          fetchpriority="high"
        />
        <div class="hero-overlay"></div>
        <div class="hero-content">
          <h1 id="hero-title">Cambridge AI for Wellbeing Society</h1>
          <p class="hero-lede">
            Responsible AI research, education, and community for human wellbeing.
          </p>
          <div class="hero-actions" aria-label="Primary actions">
            <a class="button primary" href="#contact">Join the society</a>
            <a class="button secondary" href="#events">View events</a>
          </div>
        </div>
      </section>

      <section class="intro-band" aria-label="Society summary">
        <p>
          An interdisciplinary Cambridge-based community exploring how AI systems can be
          designed, evaluated, and governed to support human flourishing.
        </p>
      </section>

      <section class="section" id="mission" aria-labelledby="mission-title">
        <div class="section-heading">
          <p class="eyebrow">Mission</p>
          <h2 id="mission-title">Technology directed toward human benefit.</h2>
        </div>
        <div class="three-grid">
          {mission.map((item) => (
            <article class="panel">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section accent" id="focus" aria-labelledby="focus-title">
        <div class="section-heading">
          <p class="eyebrow">Focus Areas</p>
          <h2 id="focus-title">Research themes at the interface of AI and wellbeing.</h2>
        </div>
        <div class="focus-grid">
          {focusAreas.map((item, index) => (
            <article class="focus-item">
              <span aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="events" aria-labelledby="events-title">
        <div class="section-heading split">
          <div>
            <p class="eyebrow">Events</p>
            <h2 id="events-title">Seminars, reading groups, and project studios.</h2>
          </div>
          <a class="text-link" href="#contact">Propose an event</a>
        </div>
        <div class="event-list">
          {events.map((event) => (
            <article class="event-card">
              <div>
                <p class="tag">{event.type}</p>
                <h3>{event.title}</h3>
                <p>{event.body}</p>
              </div>
              <span class="event-date">{event.date}</span>
            </article>
          ))}
        </div>
      </section>

      <section class="section warm" id="people" aria-labelledby="people-title">
        <div class="section-heading">
          <p class="eyebrow">People</p>
          <h2 id="people-title">A growing interdisciplinary network.</h2>
        </div>
        <div class="three-grid">
          {people.map((person) => (
            <article class="profile">
              {person.image && (
                <Image
                  class="profile-photo"
                  src={person.image}
                  alt={`Portrait of ${person.name}`}
                  width={112}
                  densities={[1, 2]}
                  format="webp"
                />
              )}
              <h3>
                {person.link ? <a href={person.link}>{person.name}</a> : person.name}
              </h3>
              <p class="role">{person.role}</p>
              <p>{person.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="projects" aria-labelledby="projects-title">
        <div class="section-heading">
          <p class="eyebrow">Projects</p>
          <h2 id="projects-title">Early directions for research and collaboration.</h2>
        </div>
        <div class="project-grid">
          {projects.map((project) => (
            <article class="project-card">
              <h3>{project.title}</h3>
              <p>{project.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="contact-section" id="contact" aria-labelledby="contact-title">
        <div class="contact-copy">
          <p class="eyebrow">Join / Contact</p>
          <h2 id="contact-title">Build the society with us.</h2>
          <p>
            We welcome students, researchers, practitioners, and partners interested in
            responsible AI for human wellbeing.
          </p>
          <div class="contact-actions">
            <a class="button secondary" href="https://github.com/ai4wellbeing">GitHub</a>
          </div>
        </div>
        <form
          class="contact-form"
          action={contactFormEndpoint || undefined}
          method="POST"
          accept-charset="UTF-8"
          data-contact-form
          data-configured={isContactFormConfigured ? 'true' : 'false'}
          aria-labelledby="contact-form-title"
        >
          <input
            type="hidden"
            name="subject"
            value="New enquiry for Cambridge AI for Wellbeing Society from {{ name }}"
          />
          <label class="form-honeypot" aria-hidden="true">
            Leave this field empty
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
          </label>

          <div class="form-intro">
            <h3 id="contact-form-title">Send an enquiry</h3>
            <p>Tell us briefly who you are and how you would like to engage.</p>
          </div>

          <div class="form-row">
            <label for="contact-name">
              Name
              <input
                id="contact-name"
                name="name"
                type="text"
                autocomplete="name"
                required
              />
            </label>
            <label for="contact-email">
              Email
              <input
                id="contact-email"
                name="email"
                type="email"
                autocomplete="email"
                required
              />
            </label>
          </div>

          <label for="contact-affiliation">
            Affiliation
            <input
              id="contact-affiliation"
              name="affiliation"
              type="text"
              autocomplete="organization"
              placeholder="College, department, company, or independent"
            />
          </label>

          <label for="contact-interest">
            Area of interest
            <select id="contact-interest" name="interest" required>
              <option value="">Select one</option>
              <option>Membership or volunteering</option>
              <option>Research collaboration</option>
              <option>Event or seminar proposal</option>
              <option>Partnership or sponsorship</option>
              <option>General enquiry</option>
            </select>
          </label>

          <label for="contact-message">
            Message
            <textarea
              id="contact-message"
              name="message"
              rows="5"
              required
              placeholder="A few sentences are enough for a first contact."
            ></textarea>
          </label>

          <div class="form-footer">
            <p class="form-status" data-form-status aria-live="polite">
              {isContactFormConfigured
                ? 'We will reply to the address you provide.'
                : 'The contact form is being connected.'}
            </p>
            <button class="button primary" type="submit" disabled={!isContactFormConfigured}>
              {isContactFormConfigured ? 'Send message' : 'Form setup pending'}
            </button>
          </div>
        </form>
      </section>
      <section class="brand-banner" aria-label="Society crest and wordmark">
        <Image
          class="brand-banner-image"
          src={brandBanner}
          alt="Cambridge AI for Wellbeing Society crest beside the society wordmark"
          width={260}
          densities={[1, 2]}
          format="webp"
          loading="lazy"
        />
      </section>
    </main>

    <footer>
      <p>
        © 2026 Cambridge AI for Wellbeing Society. Independent community initiative.
        Not an official website of the University of Cambridge.
      </p>
    </footer>
    <script is:inline>
      const contactForm = document.querySelector('[data-contact-form]');

      if (contactForm instanceof HTMLFormElement && contactForm.dataset.configured === 'true') {
        const status = contactForm.querySelector('[data-form-status]');
        const submitButton = contactForm.querySelector('button[type="submit"]');

        contactForm.addEventListener('submit', async (event) => {
          event.preventDefault();

          if (!(submitButton instanceof HTMLButtonElement)) {
            return;
          }

          submitButton.disabled = true;
          submitButton.textContent = 'Sending...';

          if (status) {
            status.textContent = 'Sending your message...';
          }

          try {
            const response = await fetch(contactForm.action, {
              method: 'POST',
              body: new FormData(contactForm),
              headers: {
                Accept: 'application/json'
              }
            });

            if (!response.ok) {
              throw new Error('Form submission failed.');
            }

            contactForm.reset();
            if (status) {
              status.textContent = 'Thank you. Your message has been sent.';
            }
          } catch {
            if (status) {
              status.textContent = 'Submission failed. Please try again later.';
            }
          } finally {
            submitButton.disabled = false;
            submitButton.textContent = 'Send message';
          }
        });
      }
    </script>
  </body>
</html>
