---
import '../styles/global.css';
import { events, focusAreas, mission, navItems, people, projects } from '../data/site';

const contactEmail = 'contact@ai4wellbeing.org';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Cambridge AI for Wellbeing Society / 智善科技 is an interdisciplinary community for responsible AI research, education, and human wellbeing."
    />
    <meta property="og:title" content="Cambridge AI for Wellbeing Society" />
    <meta
      property="og:description"
      content="Responsible AI research, education, and community for human wellbeing."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://ai4wellbeing.github.io" />
    <meta property="og:image" content="/images/cambridge-ai-wellbeing-hero.png" />
    <meta name="theme-color" content="#133844" />
    <link rel="icon" href="/favicon.svg" />
    <title>Cambridge AI for Wellbeing Society | 智善科技</title>
  </head>
  <body>
    <header class="site-header" aria-label="Primary navigation">
      <a class="brand" href="#top" aria-label="Cambridge AI for Wellbeing Society home">
        <span class="brand-mark" aria-hidden="true">AI</span>
        <span>
          <strong>AI for Wellbeing</strong>
          <small>智善科技</small>
        </span>
      </a>
      <nav>
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <img
          class="hero-image"
          src="/images/cambridge-ai-wellbeing-hero.png"
          alt="Cambridge-inspired academic courtyard with subtle AI network light patterns"
        />
        <div class="hero-overlay"></div>
        <div class="hero-content">
          <p class="eyebrow">智善科技</p>
          <h1 id="hero-title">Cambridge AI for Wellbeing Society</h1>
          <p class="hero-lede">
            Responsible AI research, education, and community for human wellbeing.
          </p>
          <div class="hero-actions" aria-label="Primary actions">
            <a class="button primary" href="#contact">Join the society</a>
            <a class="button secondary" href="#events">View events</a>
          </div>
        </div>
      </section>

      <section class="intro-band" aria-label="Society summary">
        <p>
          An interdisciplinary Cambridge-based community exploring how AI systems can be
          designed, evaluated, and governed to support human flourishing.
        </p>
      </section>

      <section class="section" id="mission" aria-labelledby="mission-title">
        <div class="section-heading">
          <p class="eyebrow">Mission</p>
          <h2 id="mission-title">Technology directed toward human benefit.</h2>
        </div>
        <div class="three-grid">
          {mission.map((item) => (
            <article class="panel">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section accent" id="focus" aria-labelledby="focus-title">
        <div class="section-heading">
          <p class="eyebrow">Focus Areas</p>
          <h2 id="focus-title">Research themes at the interface of AI and wellbeing.</h2>
        </div>
        <div class="focus-grid">
          {focusAreas.map((item, index) => (
            <article class="focus-item">
              <span aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="events" aria-labelledby="events-title">
        <div class="section-heading split">
          <div>
            <p class="eyebrow">Events</p>
            <h2 id="events-title">Seminars, reading groups, and project studios.</h2>
          </div>
          <a class="text-link" href="#contact">Propose an event</a>
        </div>
        <div class="event-list">
          {events.map((event) => (
            <article class="event-card">
              <div>
                <p class="tag">{event.type}</p>
                <h3>{event.title}</h3>
                <p>{event.body}</p>
              </div>
              <time>{event.date}</time>
            </article>
          ))}
        </div>
      </section>

      <section class="section warm" id="people" aria-labelledby="people-title">
        <div class="section-heading">
          <p class="eyebrow">People</p>
          <h2 id="people-title">A growing interdisciplinary network.</h2>
        </div>
        <div class="three-grid">
          {people.map((person) => (
            <article class="profile">
              <h3>{person.name}</h3>
              <p class="role">{person.role}</p>
              <p>{person.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="projects" aria-labelledby="projects-title">
        <div class="section-heading">
          <p class="eyebrow">Projects</p>
          <h2 id="projects-title">Early directions for research and collaboration.</h2>
        </div>
        <div class="project-grid">
          {projects.map((project) => (
            <article class="project-card">
              <h3>{project.title}</h3>
              <p>{project.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="contact-section" id="contact" aria-labelledby="contact-title">
        <div>
          <p class="eyebrow">Join / Contact</p>
          <h2 id="contact-title">Build the society with us.</h2>
          <p>
            We welcome students, researchers, practitioners, and partners interested in
            responsible AI for human wellbeing.
          </p>
        </div>
        <div class="contact-actions">
          <a class="button primary" href={`mailto:${contactEmail}`}>Email us</a>
          <a class="button secondary" href="https://github.com/ai4wellbeing">GitHub</a>
        </div>
      </section>
    </main>

    <footer>
      <p>
        © 2026 Cambridge AI for Wellbeing Society / 智善科技. Independent community
        initiative. Not an official website of the University of Cambridge.
      </p>
    </footer>
  </body>
</html>
