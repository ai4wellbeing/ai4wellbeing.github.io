---
import { Image, Picture } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { focusAreas, mission, workshop } from '../data/site';
import brandBanner from '../assets/ai4w-logo-big.png';
import heroImage from '../assets/hero.png';
---

<Layout title="Cambridge AI for Wellbeing Society">
  <section class="hero" aria-labelledby="hero-title">
    <Picture
      class="hero-image"
      src={heroImage}
      formats={['avif', 'webp']}
      fallbackFormat="jpg"
      widths={[640, 1024, 1440, heroImage.width]}
      sizes="100vw"
      alt="Cambridge-inspired academic courtyard with subtle AI network light patterns"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 id="hero-title">Cambridge AI for Wellbeing Society</h1>
      <p class="hero-lede">
        Responsible AI research, education, and community for human wellbeing.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/contact/">Join the society</a>
        <a class="button secondary" href="/events/">View events</a>
      </div>
    </div>
  </section>

  <section class="intro-band" aria-label="Society summary">
    <p>
      We are an interdisciplinary, Cambridge-based community exploring how AI can be
      designed, evaluated, and governed to support human flourishing — openly,
      responsibly, and in the public interest.
    </p>
  </section>

  <section class="section" id="mission" aria-labelledby="mission-title">
    <div class="section-heading">
      <p class="eyebrow">Mission</p>
      <h2 id="mission-title">Technology directed toward human benefit.</h2>
    </div>
    <div class="three-grid">
      {mission.map((item) => (
        <article class="panel">
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section accent" id="focus" aria-labelledby="focus-title">
    <div class="section-heading">
      <p class="eyebrow">Focus Areas</p>
      <h2 id="focus-title">Research themes at the interface of AI and wellbeing.</h2>
    </div>
    <div class="focus-grid">
      {focusAreas.map((item, index) => (
        <article class="focus-item">
          <span aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="cta-band" aria-labelledby="cta-title">
    <div>
      <p class="eyebrow">Get involved</p>
      <h2 id="cta-title">Research, learn, and build with us.</h2>
      <p>
        Our first workshop takes place on {workshop.date} — and new members are always
        welcome, from any discipline or background.
      </p>
    </div>
    <div class="contact-actions">
      <a class="button primary" href="/events/">See the workshop</a>
      <a class="button secondary" href="/contact/">Get in touch</a>
    </div>
  </section>

  <section class="brand-banner" aria-label="Society crest and wordmark">
    <Image
      class="brand-banner-image"
      src={brandBanner}
      alt="Cambridge AI for Wellbeing Society crest beside the society wordmark"
      width={260}
      densities={[1, 2]}
      format="webp"
      loading="lazy"
    />
  </section>
</Layout>
